#!/usr/bin/env bash
# Starts (or attaches) the tmux session for a 5dive agent.
# Invoked by 5dive-agent@<name>.service as User=agent-<name>.
# Reads /var/lib/5dive/agents.d/<name>.env for AGENT_TYPE, AGENT_CHANNELS, AGENT_WORKDIR.
set -euo pipefail

NAME="${1:-${AGENT_NAME:-}}"
[[ -n "$NAME" ]] || { echo "usage: 5dive-agent-start <name>" >&2; exit 2; }

ENV_FILE="/var/lib/5dive/agents.d/${NAME}.env"
[[ -r "$ENV_FILE" ]] || { echo "no env file: $ENV_FILE" >&2; exit 2; }
# shellcheck disable=SC1090
source "$ENV_FILE"

TYPE="${AGENT_TYPE:?AGENT_TYPE missing}"
CHANNELS="${AGENT_CHANNELS:-none}"
DEFAULT_WORKDIR="/home/claude/projects"
WORKDIR="${AGENT_WORKDIR:-$DEFAULT_WORKDIR}"
PROFILE="${AGENT_AUTH_PROFILE:-}"
if [[ ! -d "$WORKDIR" ]] || ! test -r "$WORKDIR"; then
  echo "warn: workdir '$WORKDIR' not accessible to $(id -un) — falling back to $DEFAULT_WORKDIR" >&2
  WORKDIR="$DEFAULT_WORKDIR"
fi

# Pull in nvm so `codex` / `gemini` / other npm-global tools are on PATH.
# Agents run as agent-<name> but shared configs point to /home/claude, so we
# source claude's nvm.sh (the agent user has no nvm of its own).
export NVM_DIR="/home/claude/.nvm"
# shellcheck disable=SC1091
[[ -s "$NVM_DIR/nvm.sh" ]] && . "$NVM_DIR/nvm.sh" || true


# openclaw splits "the agent that runs and answers chat messages"
# (`openclaw gateway run`) from "the local TUI for talking to that
# agent" (`openclaw chat`). Without a channel we want the TUI; with a
# channel we want the gateway, which polls the bot, dispatches messages
# to the agent runtime, and ships replies back. The user can still
# attach to tmux to see gateway logs, and run `openclaw chat` from a
# separate shell if they want a local TUI alongside. Default-deny on
# the case (only `none|""` runs chat) so any future channel type added
# via valid_channel automatically routes to the gateway without
# requiring a parallel update here.
case "$TYPE" in
  claude)   BIN="/home/claude/.local/bin/claude"; ARGS=(--dangerously-skip-permissions) ;;
  hermes)   BIN="/home/claude/.local/bin/hermes"; ARGS=() ;;
  openclaw)
    BIN="/home/claude/.local/bin/openclaw"
    case "$CHANNELS" in
      none|"") ARGS=(chat) ;;
      *)       ARGS=(gateway run) ;;
    esac ;;
  codex)    BIN="/home/claude/.nvm/versions/node/v24/bin/codex"; ARGS=() ;;
  gemini)   BIN="/home/claude/.nvm/versions/node/v24/bin/gemini"; ARGS=(--skip-trust --yolo) ;;
  opencode) BIN="/home/claude/.local/bin/opencode"; ARGS=() ;;
  # antigravity ships as `agy` (Google's native-Go gemini-cli successor). The
  # type id stays "antigravity" everywhere (agents.d/<name>.env, TYPE_BIN,
  # auth dispatch); only the on-disk binary is named agy. Bare launch — the
  # interactive TUI starts without args.
  antigravity) BIN="/home/claude/.local/bin/agy"; ARGS=() ;;
  # grok is xAI's CLI; the installer symlinks ~/.grok/bin/grok to
  # ~/.local/bin/grok. --always-approve auto-accepts tool/web-fetch prompts —
  # without it, inter-agent traffic stalls on the permission dialog (e.g. a
  # reuters.com fetch parked an agent for 30+ min until yolo was toggled).
  grok)     BIN="/home/claude/.local/bin/grok"; ARGS=(--always-approve) ;;
  *) echo "unknown AGENT_TYPE: $TYPE" >&2; exit 2 ;;
esac

[[ -x "$BIN" ]] || { echo "binary not installed: $BIN" >&2; exit 3; }

# Only claude flows through marketplace plugins for its channel surface
# (the dashboard install_channel_for_agent step set the bot token there).
# openclaw consumed CHANNELS in the type-dispatch above; hermes' gateway
# reads ~/.hermes/.env directly, so neither needs a runtime --channels arg.
#
# AGENT_CHANNEL_MARKETPLACE is set per-agent in /var/lib/5dive/agents.d/<name>.env
# (see write_agent_env in cmd_agent.sh). New telegram agents get
# `5dive-plugins` (our fork). Existing agents without the var fall back to
# `claude-plugins-official` so they keep loading whichever plugin they
# were originally provisioned with. Discord stays upstream — we haven't
# forked it yet.
CM="${AGENT_CHANNEL_MARKETPLACE:-claude-plugins-official}"
case "$CHANNELS" in
  none|"") : ;;
  telegram)
    case "$TYPE" in
      claude) ARGS+=(--channels "plugin:telegram@${CM}") ;;
      # codex wires the telegram MCP server + lifecycle hooks via config.toml
      # (written below). codex's first-run "Hooks need review" TUI prompt is
      # auto-accepted after launch (see the trust-accepter near the end of this
      # script) — the --dangerously-bypass-hook-trust flag does NOT suppress
      # that interactive gate (it only affects non-interactive `codex exec`).
      codex)  : ;;
    esac ;;
  discord)
    case "$TYPE" in
      claude) ARGS+=(--channels plugin:discord@claude-plugins-official) ;;
    esac ;;
  *) echo "unknown channels: $CHANNELS" >&2; exit 2 ;;
esac

# Per-profile state root for the agent's type — empty $PROFILE means the
# legacy shared /home/claude/.<type> is the seed source (default profile,
# unchanged). When a profile is bound, every per-type seed below points at
# /var/lib/5dive/auth-profiles/<profile>/<type>/ so concurrent profiled
# agents can re-auth without overwriting each other.
PROFILE_STATE_DIR=""
if [[ -n "$PROFILE" ]]; then
  PROFILE_STATE_DIR="/var/lib/5dive/auth-profiles/${PROFILE}/${TYPE}"
fi

# Codex stores OAuth tokens in $CODEX_HOME/auth.json. profile.d points
# CODEX_HOME at the shared /home/claude/.codex (mode 2770 group=claude),
# but codex writes auth.json mode 0600 — agent-<name> is in the claude group
# yet still can't read a 0600 file owned by claude. So for codex agents we
# use a per-agent CODEX_HOME under $HOME, seeded from the shared auth.json.
# After seeding, the agent owns its own token-rotation chain. We re-seed
# only when the shared file is newer (i.e. someone re-ran `5dive auth login
# codex` on the host). With a profile, the shared source is the per-profile
# auth.json under $PROFILE_STATE_DIR instead of /home/claude/.codex.
CODEX_OVERRIDE=""
if [[ "$TYPE" == "codex" ]]; then
  AGENT_CODEX_HOME="$HOME/.codex"
  install -d -m 700 "$AGENT_CODEX_HOME"
  SHARED_AUTH="${PROFILE_STATE_DIR:+$PROFILE_STATE_DIR/auth.json}"
  SHARED_AUTH="${SHARED_AUTH:-/home/claude/.codex/auth.json}"
  LOCAL_AUTH="$AGENT_CODEX_HOME/auth.json"
  if [[ -e "$SHARED_AUTH" ]] && { [[ ! -f "$LOCAL_AUTH" ]] || [[ "$SHARED_AUTH" -nt "$LOCAL_AUTH" ]]; }; then
    TMP="$(mktemp -p "$AGENT_CODEX_HOME" .auth.XXXXXX)"
    if sudo -n cat "$SHARED_AUTH" > "$TMP" 2>/dev/null; then
      chmod 600 "$TMP"
      mv "$TMP" "$LOCAL_AUTH"
    else
      rm -f "$TMP"
      echo "warn: could not seed codex auth.json from $SHARED_AUTH" >&2
    fi
  fi
  # Bypass codex's first-run trust prompt + approval/sandbox dialogs. Mirrors
  # the `--dangerously-skip-permissions` posture we use for claude-family.
  #
  # Create-if-missing only. Writing this unconditionally on every start
  # clobbered anything the user added to config.toml — most importantly
  # [mcp_servers.*] sections added via `codex mcp add`, which an agent
  # restart then silently wiped. We seed the required keys once, on first
  # start (before any MCP server could exist); thereafter the file is the
  # user's to extend and we never touch it. A merge that appended only the
  # missing keys was considered but rejected: appending a bare top-level key
  # after an existing [table] header binds it to that table in TOML, so it
  # can't be done safely without a real parser.
  if [[ ! -f "$AGENT_CODEX_HOME/config.toml" ]]; then
    cat > "$AGENT_CODEX_HOME/config.toml" <<TOML
approval_policy = "never"
sandbox_mode = "danger-full-access"
check_for_update_on_startup = false

[projects."${WORKDIR}"]
trust_level = "trusted"
TOML
    chmod 600 "$AGENT_CODEX_HOME/config.toml"
  fi
  # Wire the telegram-codex MCP server + lifecycle hooks into config.toml when
  # this agent has the telegram channel. We append complete [sections] only
  # when [mcp_servers.telegram] isn't already present — appending whole tables
  # is TOML-safe (unlike bare keys after a table header, see note above), and
  # the guard makes this idempotent across restarts and safe for the
  # post-create channel-attach path (config.toml already exists from an earlier
  # boot). Hook trust is handled by --dangerously-bypass-hook-trust (added to
  # ARGS in the channels switch), so no [hooks.state] hashes are needed. The
  # plugin is a single shared checkout; server.ts + the hooks resolve this
  # agent's own ~/.codex/channels/telegram state via homedir(), so one copy
  # serves every codex agent. Resolver kept in sync with codex_plugin_dir() in
  # src/lib/agent_setup.sh.
  if [[ "$CHANNELS" == "telegram" ]] \
     && ! grep -q '^\[mcp_servers\.telegram\]' "$AGENT_CODEX_HOME/config.toml" 2>/dev/null; then
    CODEX_PLUGIN_DIR=""
    for _c in "${TELEGRAM_CODEX_PLUGIN_DIR:-}" \
              /usr/local/lib/5dive/telegram-codex \
              /home/claude/projects/5dive/5dive-plugins/plugins/telegram-codex; do
      [[ -n "$_c" && -f "$_c/server.ts" ]] && { CODEX_PLUGIN_DIR="$_c"; break; }
    done
    if [[ -n "$CODEX_PLUGIN_DIR" ]]; then
      cat >> "$AGENT_CODEX_HOME/config.toml" <<TOML

[mcp_servers.telegram]
command = "bun"
args = ["${CODEX_PLUGIN_DIR}/server.ts"]

[features]
hooks = true

[[hooks.Stop]]

[[hooks.Stop.hooks]]
type = "command"
command = "bun ${CODEX_PLUGIN_DIR}/hooks/notify-stop.ts"
async = false

[[hooks.PreToolUse]]

[[hooks.PreToolUse.hooks]]
type = "command"
command = "bun ${CODEX_PLUGIN_DIR}/hooks/silence-watchdog.ts"
async = false

[[hooks.Notification]]

[[hooks.Notification.hooks]]
type = "command"
command = "bun ${CODEX_PLUGIN_DIR}/hooks/notification-relay.ts"
async = false

[[hooks.PermissionRequest]]

[[hooks.PermissionRequest.hooks]]
type = "command"
command = "bun ${CODEX_PLUGIN_DIR}/hooks/request-permission.ts"
timeout = 180
async = false
TOML
    else
      echo "warn: telegram channel set for codex agent '$NAME' but telegram-codex plugin not found (TELEGRAM_CODEX_PLUGIN_DIR / /usr/local/lib/5dive/telegram-codex / 5dive-plugins checkout) — MCP + hooks not wired" >&2
    fi
  fi
  CODEX_OVERRIDE="export CODEX_HOME=$(printf %q "$AGENT_CODEX_HOME"); "
fi

# Grok stores OAuth tokens in $HOME/.grok/auth.json (mode 0600). Same shared/
# 0600 problem as codex: the host-level shared copy at /home/claude/.grok/
# auth.json is owned by `claude` and unreadable to agent-<name> even though
# it's in the claude group. Seed the agent's own ~/.grok/auth.json from the
# shared file via sudo, re-seeding only when the shared copy is newer (so a
# host-side `5dive auth login grok` propagates on the next agent restart).
# Unlike codex, grok has no *_HOME env var — it always reads $HOME/.grok —
# so no per-agent CODEX_HOME-style override is needed. With a profile, the
# source is $PROFILE_STATE_DIR/.grok/auth.json (matches profile_type_auth_path
# in src/cmd_auth.sh).
if [[ "$TYPE" == "grok" ]]; then
  AGENT_GROK_HOME="$HOME/.grok"
  install -d -m 700 "$AGENT_GROK_HOME"
  SHARED_GROK_AUTH="${PROFILE_STATE_DIR:+$PROFILE_STATE_DIR/.grok/auth.json}"
  SHARED_GROK_AUTH="${SHARED_GROK_AUTH:-/home/claude/.grok/auth.json}"
  LOCAL_GROK_AUTH="$AGENT_GROK_HOME/auth.json"
  # Profile dirs are mode 0700 owner=claude, so a naive `[[ -e ]]` returns
  # false because agent-<name> can't traverse it. Route both checks through
  # `sudo -n test` (same fix as the hermes/openclaw seeds below).
  if sudo -n test -e "$SHARED_GROK_AUTH" 2>/dev/null \
     && { [[ ! -f "$LOCAL_GROK_AUTH" ]] || sudo -n test "$SHARED_GROK_AUTH" -nt "$LOCAL_GROK_AUTH"; }; then
    TMP="$(mktemp -p "$AGENT_GROK_HOME" .auth.XXXXXX)"
    if sudo -n cat "$SHARED_GROK_AUTH" > "$TMP" 2>/dev/null; then
      chmod 600 "$TMP"
      mv "$TMP" "$LOCAL_GROK_AUTH"
    else
      rm -f "$TMP"
      echo "warn: could not seed grok auth.json from $SHARED_GROK_AUTH" >&2
    fi
  fi
fi

# Wire the telegram-grok MCP server + lifecycle hooks for this grok agent
# when channels=telegram. Same shape as the codex block above: a single shared
# plugin checkout serves every grok agent (server.ts + hooks resolve state
# from $HOME via homedir()). grok's --always-approve flag (set in ARGS above)
# auto-trusts plugin/MCP commands so no separate trust-bypass step is needed.
#
# Two files because grok splits the surface:
#   1. ~/.grok/config.toml  → [mcp_servers.telegram] only. ${GROK_PLUGIN_ROOT}
#      isn't expanded in MCP command/args in grok 0.1.x, so we write absolute
#      paths at boot. Idempotent: skipped when the [mcp_servers.telegram]
#      header is already present.
#   2. ~/.grok/hooks/5dive-telegram.json → lifecycle hooks. Grok ignores
#      [[hooks.*]] inside config.toml and only loads ~/.grok/hooks/*.json
#      (verified via `grok inspect` — hooks defined in config.toml never show
#      up in the merged set). Atomic mv-into-place so we can re-render on
#      every boot to pick up plugin-dir changes without leaving a partial
#      file under a crash.
if [[ "$TYPE" == "grok" ]] && [[ "$CHANNELS" == "telegram" ]]; then
  AGENT_GROK_HOME="$HOME/.grok"
  install -d -m 700 "$AGENT_GROK_HOME"
  GROK_PLUGIN_DIR=""
  for _c in "${TELEGRAM_GROK_PLUGIN_DIR:-}" \
            /usr/local/lib/5dive/telegram-grok \
            /home/claude/projects/5dive/5dive-plugins/plugins/telegram-grok; do
    [[ -n "$_c" && -f "$_c/server.ts" ]] && { GROK_PLUGIN_DIR="$_c"; break; }
  done
  if [[ -n "$GROK_PLUGIN_DIR" ]]; then
    if [[ ! -f "$AGENT_GROK_HOME/config.toml" ]]; then
      : > "$AGENT_GROK_HOME/config.toml"
      chmod 600 "$AGENT_GROK_HOME/config.toml"
    fi
    if ! grep -q '^\[mcp_servers\.telegram\]' "$AGENT_GROK_HOME/config.toml" 2>/dev/null; then
      # tool_timeouts.wait_for_message: server.ts caps wait at 50s by default;
      # grok's tool_timeout_sec defaults to 60. Bump to 60s so an idle poll
      # near the boundary doesn't get killed by the outer timeout.
      cat >> "$AGENT_GROK_HOME/config.toml" <<TOML

[mcp_servers.telegram]
command = "bun"
args = ["${GROK_PLUGIN_DIR}/server.ts"]
tool_timeouts = { wait_for_message = 60 }
TOML
    fi

    install -d -m 700 "$AGENT_GROK_HOME/hooks"
    HOOKS_TMP=$(mktemp -p "$AGENT_GROK_HOME/hooks" .5dive-telegram.json.XXXXXX)
    cat > "$HOOKS_TMP" <<HOOKS_JSON
{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "bun ${GROK_PLUGIN_DIR}/hooks/silence-watchdog.ts", "timeout": 5 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "bun ${GROK_PLUGIN_DIR}/hooks/notify-stop.ts", "timeout": 10 }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "bun ${GROK_PLUGIN_DIR}/hooks/notification-relay.ts", "timeout": 10 }
        ]
      }
    ]
  }
}
HOOKS_JSON
    chmod 600 "$HOOKS_TMP"
    mv "$HOOKS_TMP" "$AGENT_GROK_HOME/hooks/5dive-telegram.json"
  else
    echo "warn: telegram channel set for grok agent '$NAME' but telegram-grok plugin not found (TELEGRAM_GROK_PLUGIN_DIR / /usr/local/lib/5dive/telegram-grok / 5dive-plugins checkout) — MCP + hooks not wired" >&2
  fi
fi

# Same shared/0600 problem as codex: hermes writes ~/.hermes/auth.json with
# mode 0600 after `hermes auth add openai-codex`. agent-<name> can't read a
# 0600 file owned by `claude` even though it's in the claude group. Seed the
# agent's own ~/.hermes/auth.json from the shared file via sudo (re-seeding
# only when the shared copy is newer, e.g. after a fresh device-code login).
# HERMES_HOME defaults to $HOME/.hermes inside hermes itself, so we don't
# need to override it once the per-agent auth.json is in place.
#
# Profile-scoped path: HERMES_HOME points at $PROFILE_STATE_DIR during the
# device-code login, so `hermes auth add openai-codex` writes auth.json
# there *and* tightens the dir back to mode 0700 owner=claude. agent-<name>
# can't even traverse a 0700 dir, so a naive `[[ -e "$SHARED" ]]` returns
# false and the seed silently no-ops — leaving the agent with no auth.json
# and hermes erroring "No Codex credentials stored." on every message.
# Route both checks through `sudo -n test` (same fix as openclaw below).
if [[ "$TYPE" == "hermes" ]]; then
  AGENT_HERMES_HOME="$HOME/.hermes"
  install -d -m 700 "$AGENT_HERMES_HOME"
  SHARED_HERMES_DIR="${PROFILE_STATE_DIR:-/home/claude/.hermes}"
  hermes_seeded=0
  # Seed auth.json + config.yaml from the shared/profile dir. auth.json uses
  # an mtime check (newer SHARED wins) because both sides legitimately rotate
  # tokens. config.yaml uses a content-diff because `hermes gateway install`
  # (run during `cmd_create`) pre-writes a default config.yaml with
  # provider=openai-codex into the agent user's dir *before* this seed loop
  # runs — its mtime is freshly later than SHARED so an mtime-only test would
  # silently lose the user's BYO provider choice. The profile dir's
  # config.yaml is authoritative for model/provider; any drift in LOCAL just
  # means hermes wrote a fresh default that needs to be overridden.
  seed_one() {
    local f="$1" mode="$2"  # mode: mtime | content
    local SHARED="$SHARED_HERMES_DIR/$f"
    local LOCAL="$AGENT_HERMES_HOME/$f"
    sudo -n test -e "$SHARED" || return 0
    local stale=0
    if [[ ! -f "$LOCAL" ]]; then
      stale=1
    elif [[ "$mode" == "content" ]]; then
      sudo -n cmp -s "$SHARED" "$LOCAL" 2>/dev/null || stale=1
    else
      sudo -n test "$SHARED" -nt "$LOCAL" && stale=1
    fi
    (( stale )) || return 0
    local TMP
    TMP="$(mktemp -p "$AGENT_HERMES_HOME" ".${f}.XXXXXX")"
    if sudo -n cat "$SHARED" > "$TMP" 2>/dev/null; then
      chmod 600 "$TMP"
      mv "$TMP" "$LOCAL"
      hermes_seeded=1
    else
      rm -f "$TMP"
      echo "warn: could not seed hermes $f from $SHARED" >&2
    fi
  }
  seed_one auth.json   mtime
  seed_one config.yaml content
  # hermes' messaging gateway is a long-lived user daemon that survives
  # `systemctl restart 5dive-agent@<name>` (cmd_restart bounces the tmux
  # unit; the gateway is a separate `loginctl enable-linger`'d process that
  # caches model.provider in memory at startup). Always bounce it on agent
  # start so an explicit `agent restart` reliably picks up provider/config
  # changes — even when the change landed outside the profile dir (e.g.
  # the operator edited `/home/claude/.hermes/config.yaml` directly or
  # used hermes' own CLI) and the seed loop above had nothing to copy.
  if [[ -x "$BIN" ]]; then
    "$BIN" gateway restart >&2 2>&1 \
      || echo "warn: hermes gateway restart failed — new config will only take effect on next boot" >&2
  fi
fi

# Same shared/0600 problem as codex/hermes: openclaw writes its OAuth tokens to
# ~/.openclaw/agents/main/agent/auth-profiles.json (mode 0600) after
# `openclaw models auth login --provider openai-codex --method device-code`.
# agent-<name> can't read a 0600 file owned by `claude` even though it's in the
# claude group. Seed the agent's own copy from the shared file via sudo (re-
# seeding only when the shared copy is newer, e.g. after a fresh device-code
# login). openclaw's resolveStateDir respects the process HOME, so $HOME/
# .openclaw is the path each agent process reads.
if [[ "$TYPE" == "openclaw" ]]; then
  AGENT_OPENCLAW_DIR="$HOME/.openclaw/agents/main/agent"
  install -d -m 700 "$HOME/.openclaw"
  install -d -m 700 "$HOME/.openclaw/agents"
  install -d -m 700 "$HOME/.openclaw/agents/main"
  install -d -m 700 "$AGENT_OPENCLAW_DIR"
  # Profile-scoped login lands at $PROFILE_STATE_DIR/.openclaw/agents/main/
  # agent/auth-profiles.json — that's the path cmd_auth_start created via
  # HOME=$PROFILE_STATE_DIR redirect. Default profile keeps the legacy
  # shared /home/claude/.openclaw layout.
  SHARED_OPENCLAW_AUTH="${PROFILE_STATE_DIR:+$PROFILE_STATE_DIR/.openclaw/agents/main/agent/auth-profiles.json}"
  SHARED_OPENCLAW_AUTH="${SHARED_OPENCLAW_AUTH:-/home/claude/.openclaw/agents/main/agent/auth-profiles.json}"
  LOCAL_OPENCLAW_AUTH="$AGENT_OPENCLAW_DIR/auth-profiles.json"
  # The shared openclaw state dirs land at mode 0700 owner=claude, so the
  # agent user can't even traverse them — `[[ -e "$SHARED" ]]` returns false
  # and the seed block silently no-ops. The agent user has NOPASSWD sudo
  # though, so route the existence + staleness checks through sudo (same
  # mechanism the cat below already uses).
  if sudo -n test -e "$SHARED_OPENCLAW_AUTH" \
      && { [[ ! -f "$LOCAL_OPENCLAW_AUTH" ]] \
           || sudo -n test "$SHARED_OPENCLAW_AUTH" -nt "$LOCAL_OPENCLAW_AUTH"; }; then
    TMP="$(mktemp -p "$AGENT_OPENCLAW_DIR" .auth-profiles.XXXXXX)"
    if sudo -n cat "$SHARED_OPENCLAW_AUTH" > "$TMP" 2>/dev/null; then
      chmod 600 "$TMP"
      mv "$TMP" "$LOCAL_OPENCLAW_AUTH"
    else
      rm -f "$TMP"
      echo "warn: could not seed openclaw auth-profiles.json from $SHARED_OPENCLAW_AUTH" >&2
    fi
  fi

  # Inherit the profile's model defaults (`agents.defaults.model.primary`).
  # `openclaw models auth login --set-default` writes that key into the
  # *profile's* openclaw.json — but the agent has its own openclaw.json
  # (channels + gateway token + telegram allowlist live there), so without
  # this sync the gateway falls back to the openclaw global default of
  # openai/gpt-5.5 and rejects every message with "Missing API key for
  # OpenAI" since the agent only has openai-codex OAuth, not an OpenAI key.
  # Patching every launch (rather than once at create time) means a later
  # `5dive agent auth login openclaw` flips the model on next restart with
  # no agent-recreate dance.
  SHARED_OPENCLAW_CFG="${PROFILE_STATE_DIR:+$PROFILE_STATE_DIR/.openclaw/openclaw.json}"
  SHARED_OPENCLAW_CFG="${SHARED_OPENCLAW_CFG:-/home/claude/.openclaw/openclaw.json}"
  LOCAL_OPENCLAW_CFG="$HOME/.openclaw/openclaw.json"
  if sudo -n test -e "$SHARED_OPENCLAW_CFG" && [[ -f "$LOCAL_OPENCLAW_CFG" ]]; then
    PROFILE_DEFAULTS="$(sudo -n cat "$SHARED_OPENCLAW_CFG" 2>/dev/null \
      | python3 -c 'import json,sys
try:
    cfg = json.load(sys.stdin)
except Exception:
    sys.exit(0)
defaults = cfg.get("agents", {}).get("defaults")
if isinstance(defaults, dict) and defaults.get("model"):
    print(json.dumps({"agents": {"defaults": defaults}}))
' 2>/dev/null || true)"
    LOCAL_PRIMARY="$(python3 -c 'import json,sys
try:
    cfg = json.load(open(sys.argv[1]))
except Exception:
    print("")
    sys.exit(0)
m = cfg.get("agents", {}).get("defaults", {}).get("model")
if isinstance(m, dict):
    print(m.get("primary") or "")
elif isinstance(m, str):
    print(m)
' "$LOCAL_OPENCLAW_CFG" 2>/dev/null || true)"
    PROFILE_PRIMARY="$(printf '%s' "$PROFILE_DEFAULTS" | python3 -c 'import json,sys
try:
    cfg = json.load(sys.stdin)
except Exception:
    sys.exit(0)
m = cfg.get("agents", {}).get("defaults", {}).get("model")
if isinstance(m, dict):
    print(m.get("primary") or "")
elif isinstance(m, str):
    print(m)
' 2>/dev/null || true)"
    if [[ -n "$PROFILE_DEFAULTS" && "$LOCAL_PRIMARY" != "$PROFILE_PRIMARY" ]]; then
      printf '%s' "$PROFILE_DEFAULTS" \
        | /home/claude/.local/bin/openclaw config patch --stdin >/dev/null 2>&1 \
        || echo "warn: openclaw config patch (model defaults) failed" >&2
    fi
  fi
fi

# Same shared/0600 problem as codex: gemini stores OAuth tokens in
# ~/.gemini/oauth_creds.json (mode 0600), and there's no GEMINI_HOME env to
# redirect — gemini reads $HOME/.gemini directly. So seed the agent's own
# ~/.gemini/oauth_creds.json from the shared file via sudo (re-seeding only
# when the shared copy is newer, e.g. after `5dive auth login gemini`).
# We also pin settings.json's selectedType to "oauth-personal" so gemini
# skips the auth-method picker on launch, matching the auth-login preseed.
if [[ "$TYPE" == "gemini" ]]; then
  AGENT_GEMINI_HOME="$HOME/.gemini"
  install -d -m 700 "$AGENT_GEMINI_HOME"
  # Profile-scoped login lands at $PROFILE_STATE_DIR/.gemini/oauth_creds.json
  # — that's the path cmd_auth_start created via HOME=$PROFILE_STATE_DIR
  # redirect (gemini reads $HOME/.gemini, no GEMINI_HOME). Default profile
  # keeps the legacy shared /home/claude/.gemini layout.
  SHARED_GEMINI_AUTH="${PROFILE_STATE_DIR:+$PROFILE_STATE_DIR/.gemini/oauth_creds.json}"
  SHARED_GEMINI_AUTH="${SHARED_GEMINI_AUTH:-/home/claude/.gemini/oauth_creds.json}"
  LOCAL_GEMINI_AUTH="$AGENT_GEMINI_HOME/oauth_creds.json"
  if [[ -e "$SHARED_GEMINI_AUTH" ]] && { [[ ! -f "$LOCAL_GEMINI_AUTH" ]] || [[ "$SHARED_GEMINI_AUTH" -nt "$LOCAL_GEMINI_AUTH" ]]; }; then
    TMP="$(mktemp -p "$AGENT_GEMINI_HOME" .creds.XXXXXX)"
    if sudo -n cat "$SHARED_GEMINI_AUTH" > "$TMP" 2>/dev/null; then
      chmod 600 "$TMP"
      mv "$TMP" "$LOCAL_GEMINI_AUTH"
    else
      rm -f "$TMP"
      echo "warn: could not seed gemini oauth_creds.json from $SHARED_GEMINI_AUTH" >&2
    fi
  fi
  SETTINGS="$AGENT_GEMINI_HOME/settings.json"
  (jq '. + {security: ((.security // {}) + {auth: ((.security.auth // {}) + {selectedType: "oauth-personal"})})}' "$SETTINGS" 2>/dev/null \
    || echo '{"security":{"auth":{"selectedType":"oauth-personal"}}}') > "$SETTINGS.tmp" \
    && mv "$SETTINGS.tmp" "$SETTINGS"
  chmod 600 "$SETTINGS"
fi

# Same shared/0600 problem as gemini: antigravity (`agy`) stores its OAuth
# token at ~/.gemini/antigravity-cli/antigravity-oauth-token (mode 0600). It
# tries the OS keyring first but falls back to this file when dbus-launch is
# absent — which it always is on our headless boxes (verified in agy's cli.log:
# "Failed to load token from keyring, falling back to file"). There's no env to
# redirect the path; agy reads $HOME/.gemini directly. So seed the agent's own
# copy from the shared/profile token via sudo (re-seeding only when the shared
# copy is newer, e.g. after a fresh `5dive auth login antigravity`).
#
# Profile-scoped login lands at
# $PROFILE_STATE_DIR/.gemini/antigravity-cli/antigravity-oauth-token (the path
# cmd_auth_start created via the HOME=$PROFILE_STATE_DIR redirect). Default
# profile keeps the legacy shared /home/claude/.gemini layout. The profile dir
# is mode 0700 owner=claude, so route the existence + staleness checks through
# `sudo -n test` (same as hermes/openclaw) — a plain `[[ -e ]]` returns false
# on an untraversable dir and the seed silently no-ops, leaving the agent
# unauthenticated and agy stuck on its login prompt.
if [[ "$TYPE" == "antigravity" ]]; then
  AGENT_AGY_DIR="$HOME/.gemini/antigravity-cli"
  install -d -m 700 "$HOME/.gemini"
  install -d -m 700 "$AGENT_AGY_DIR"
  SHARED_AGY_AUTH="${PROFILE_STATE_DIR:+$PROFILE_STATE_DIR/.gemini/antigravity-cli/antigravity-oauth-token}"
  SHARED_AGY_AUTH="${SHARED_AGY_AUTH:-/home/claude/.gemini/antigravity-cli/antigravity-oauth-token}"
  LOCAL_AGY_AUTH="$AGENT_AGY_DIR/antigravity-oauth-token"
  if sudo -n test -e "$SHARED_AGY_AUTH" \
      && { [[ ! -f "$LOCAL_AGY_AUTH" ]] \
           || sudo -n test "$SHARED_AGY_AUTH" -nt "$LOCAL_AGY_AUTH"; }; then
    TMP="$(mktemp -p "$AGENT_AGY_DIR" .oauth.XXXXXX)"
    if sudo -n cat "$SHARED_AGY_AUTH" > "$TMP" 2>/dev/null; then
      chmod 600 "$TMP"
      mv "$TMP" "$LOCAL_AGY_AUTH"
    else
      rm -f "$TMP"
      echo "warn: could not seed antigravity oauth token from $SHARED_AGY_AUTH" >&2
    fi
  fi

  # Pre-complete agy's first-run onboarding so a freshly-created agent drops
  # straight into the chat instead of the interactive color-scheme / ToS /
  # folder-trust wizard (mirrors gemini's settings.json pinning). Empirically
  # (agy 1.0.3) onboarding is gated by three files; seed all create-if-missing
  # so we never fight the user's later edits:
  #   cache/onboarding.json → marks the color-scheme + ToS steps done
  #   settings.json:enableTelemetry=false → skips the data-collection consent
  #     (and opts out by default — privacy-safe; the user can flip it in-app)
  #   settings.json:trustedWorkspaces=[WORKDIR] → skips the per-folder "Do you
  #     trust this project?" gate for the agent's own workspace (agy keys trust
  #     by the cwd it launches in, which is $WORKDIR via tmux new-session -c)
  install -d -m 700 "$AGENT_AGY_DIR/cache"
  AGY_ONBOARD="$AGENT_AGY_DIR/cache/onboarding.json"
  if [[ ! -f "$AGY_ONBOARD" ]]; then
    printf '%s\n' '{"consumerOnboardingComplete":true,"enterpriseOnboardingComplete":false,"onboardingComplete":true}' > "$AGY_ONBOARD"
    chmod 600 "$AGY_ONBOARD"
  fi
  AGY_SETTINGS="$AGENT_AGY_DIR/settings.json"
  if [[ ! -f "$AGY_SETTINGS" ]]; then
    jq -n --arg ws "$WORKDIR" '{enableTelemetry:false, trustedWorkspaces:[$ws]}' > "$AGY_SETTINGS" 2>/dev/null \
      || printf '{"enableTelemetry":false,"trustedWorkspaces":["%s"]}\n' "$WORKDIR" > "$AGY_SETTINGS"
    chmod 600 "$AGY_SETTINGS"
  fi
fi

SESSION="agent-${NAME}"

# Reset any stale session from a previous unit run.
/usr/bin/tmux kill-session -t "$SESSION" 2>/dev/null || true

# Build the inner command as a single shell string so the restart loop stays
# inside the tmux window.
# The leading `unset CLAUDE_CONFIG_DIR` drops profile.d/5dive-shared-configs.sh's
# redirect to /home/claude/.claude (mode 0600, unreadable to agent-<name>) so
# claude-family binaries read the per-agent preseed at $HOME/.claude/settings.json
# (bypassPermissions, telegram plugin, StopFailure hook). Non-claude types don't
# use CLAUDE_CONFIG_DIR, so unsetting it unconditionally is safe.
#
# Auth-profile note: %i-auth.env (loaded by systemd as EnvironmentFile) is what
# swaps the CLAUDE_CODE_OAUTH_TOKEN / ANTHROPIC_API_KEY / etc. for a specific
# profile — no CLAUDE_CONFIG_DIR gymnastics needed. We keep the unset below
# (per-agent preseed still wants to win over the shared /home/claude/.claude).
# Credential scrub: the systemd template (5dive-agent@.service) EnvironmentFile=s
# anthropic.env / openai.env / gemini.env unconditionally so the auth-profile
# %i-auth.env overlay can override any of them via last-wins. The side effect
# is that anthropic.env's CLAUDE_CODE_OAUTH_TOKEN leaks into the env of
# hermes/openclaw/codex/etc. agents — and hermes' provider="auto" detection
# then routes requests to Anthropic, the exact third-party-harness pattern
# Anthropic flagged for suspension in April 2026. Drop cross-type creds
# before exec so each agent only sees env vars for its own provider.
case "$TYPE" in
  claude)
    UNSET_CREDS="OPENAI_API_KEY GEMINI_API_KEY GOOGLE_API_KEY" ;;
  codex|opencode)
    UNSET_CREDS="CLAUDE_CODE_OAUTH_TOKEN ANTHROPIC_API_KEY GEMINI_API_KEY GOOGLE_API_KEY" ;;
  gemini)
    UNSET_CREDS="CLAUDE_CODE_OAUTH_TOKEN ANTHROPIC_API_KEY OPENAI_API_KEY" ;;
  hermes|openclaw)
    # OAuth via auth.json — no provider env vars belong here.
    UNSET_CREDS="CLAUDE_CODE_OAUTH_TOKEN ANTHROPIC_API_KEY OPENAI_API_KEY GEMINI_API_KEY GOOGLE_API_KEY" ;;
  antigravity|grok)
    # OAuth via auth file (~/.gemini/antigravity-cli/* and ~/.grok/auth.json).
    # Same cross-provider leak posture as hermes/openclaw — drop everything.
    UNSET_CREDS="CLAUDE_CODE_OAUTH_TOKEN ANTHROPIC_API_KEY OPENAI_API_KEY GEMINI_API_KEY GOOGLE_API_KEY" ;;
  *)
    UNSET_CREDS="" ;;
esac

# One-shot session resume (claude only): the telegram plugin's /resume writes
# the checkpointed session id to $HOME/.claude/channels/telegram/resume-next
# and triggers this unit restart. We add `--resume <id>` to the FIRST claude
# launch of this run, then start fresh on any later loop respawn — so a crash
# or normal exit returns to a clean session rather than re-loading the old one.
# The marker is consumed (deleted) regardless of validity so a stuck file can't
# wedge the agent into permanent resume. The id is validated to a UUID shape
# before it ever reaches the claude argv.
RESUME_ID=""
if [[ "$TYPE" == "claude" ]]; then
  RESUME_MARKER="$HOME/.claude/channels/telegram/resume-next"
  if [[ -s "$RESUME_MARKER" ]]; then
    _cand="$(head -n1 "$RESUME_MARKER" | tr -d '[:space:]')"
    [[ "$_cand" =~ ^[0-9a-fA-F-]{36}$ ]] && RESUME_ID="$_cand"
    rm -f "$RESUME_MARKER"
  fi
fi

CMD_STR=$(printf '%q ' "$BIN" "${ARGS[@]}")

# First-attach onboarding for openclaw with no channel: openclaw chat is the
# bare TUI and never surfaces channel setup, so a non-technical user has no
# obvious way to wire telegram/discord/etc. after agent create. Run
# `openclaw configure` once on first attach so the user sees the channel
# wizard, then drop into chat (and stay there on every subsequent attach).
# Sentinel lives in $HOME/.openclaw so it's per-agent; rm it to re-run.
PRELUDE=""
if [[ "$TYPE" == "openclaw" ]] && [[ "$CHANNELS" == "none" || -z "$CHANNELS" ]]; then
  SENTINEL_Q=$(printf %q "$HOME/.openclaw/.5dive-bootstrapped")
  BIN_Q=$(printf %q "$BIN")
  PRELUDE="[[ -e ${SENTINEL_Q} ]] || { mkdir -p $(printf %q "$HOME/.openclaw"); ${BIN_Q} configure; touch ${SENTINEL_Q}; }; "
fi

# When a resume id is armed, the first loop iteration launches with
# `--resume <id>`; subsequent respawns fall back to the plain CMD_STR. No
# resume id → byte-identical to the original simple loop.
if [[ -n "$RESUME_ID" ]]; then
  CMD_STR_FIRST=$(printf '%q ' "$BIN" --resume "$RESUME_ID" "${ARGS[@]}")
  LOOP="__first=1; while true; do if [[ \$__first == 1 ]]; then ${CMD_STR_FIRST}; __first=0; else ${CMD_STR}; fi; sleep 2; done"
else
  LOOP="while true; do ${CMD_STR}; sleep 2; done"
fi

INNER="unset CLAUDE_CONFIG_DIR ${UNSET_CREDS}; ${CODEX_OVERRIDE}${PRELUDE}${LOOP}"
[[ -n "$PROFILE" ]] && echo "[5dive] agent=${NAME} using auth-profile=${PROFILE}" >&2

/usr/bin/tmux new-session -d -s "$SESSION" -c "$WORKDIR" \
  "bash --login -c $(printf %q "$INNER")"

# Auto-accept codex's first-run "Hooks need review" TUI prompt for telegram
# codex agents. The prompt blocks an unattended agent until dismissed, and
# codex's --dangerously-bypass-hook-trust flag doesn't suppress it (interactive
# only). We can't pre-seed [hooks.state] because codex's trusted_hash is opaque
# — so we let codex compute + persist it by selecting "Trust all and continue"
# (Down, then Enter), exactly as a human would. Once persisted, codex never
# prompts again, so we skip this entirely when [hooks.state] already exists.
# Backgrounded so it never delays the session-watch below; bounded to the boot
# window. Runs once per systemd start (codex respawns inside the tmux loop read
# the persisted trust, so they never re-prompt).
if [[ "$TYPE" == "codex" && "$CHANNELS" == "telegram" ]] \
   && ! grep -q '^\[hooks\.state\]' "$AGENT_CODEX_HOME/config.toml" 2>/dev/null; then
  (
    for _ in $(seq 1 24); do
      sleep 2
      _pane="$(/usr/bin/tmux capture-pane -t "$SESSION" -p -S -60 2>/dev/null)" || break
      if printf '%s' "$_pane" | grep -q "Hooks need review"; then
        /usr/bin/tmux send-keys -t "$SESSION" Down
        sleep 1
        /usr/bin/tmux send-keys -t "$SESSION" Enter
        break
      fi
    done
  ) &
fi

# Block so systemd keeps the unit "active" as long as the session lives.
while /usr/bin/tmux has-session -t "$SESSION" 2>/dev/null; do
  sleep 5
done
